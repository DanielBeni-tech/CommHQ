# ─────────────────────────────────────────────────────────────
# Configuration du backend CommHQ (à dupliquer en .env)
# ─────────────────────────────────────────────────────────────

# Port d'écoute du serveur HTTP/WebSocket
PORT=3000

# URL CORS autorisée pour le frontend (ex. http://localhost:5173 pour Vite)
CORS_ORIGIN=http://localhost:5173

# ─── Base de données MongoDB ────────────────────────────────
# Format : mongodb://<user>:<password>@<host>:<port>/<db>?authSource=admin
MONGODB_URI=mongodb://localhost:27017/commhq

# ─── Authentification JWT ───────────────────────────────────
# Générer des secrets longs et aléatoires en production !
JWT_SECRET=remplace-moi-par-un-secret-tres-long-et-aleatoire
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=remplace-moi-aussi
JWT_REFRESH_EXPIRES_IN=7d

# ─── Invitations ────────────────────────────────────────────
# Durée de validité (en heures) d'un lien d'invitation
INVITATION_TTL_HOURS=72

# URL publique du frontend (utilisée pour construire les liens d'invitation)
FRONTEND_URL=http://localhost:5173

# ─── Bot IA (résumé en 3 phrases) ───────────────────────────
# Mettre AI_PROVIDER=mock pour utiliser le résumé local (pas d'appel externe).
# Mettre AI_PROVIDER=openai pour utiliser l'API OpenAI.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
